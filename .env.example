SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-public-key
# Folosit de crons Vercel (Authorization: Bearer ...) si de /api/notifications/dispatch in productie.
CRON_SECRET=your-random-sync-secret
# Same comma-separated list on server + client; used to promote profiles.role to admin after login (POST /api/fixtures/day?syncBootstrapAdmin=1).
ADMIN_EMAILS=admin@your-domain.com
VITE_ADMIN_EMAILS=admin@your-domain.com
RESEND_API_KEY=your-resend-api-key
NOTIFY_FROM_EMAIL=alerts@your-domain.com
BACKTEST_DAYS=45

# Optional: used by existing API fetch layer
X_RAPIDAPI_KEY=your-rapidapi-key
X_RAPIDAPI_HOST=api-football-v1.p.rapidapi.com
UPSTREAM_BASE_URL=https://api-football-v1.p.rapidapi.com/v3

# Optional: cache prewarm cron configuration
PREWARM_LEAGUE_IDS=39,140,135,78,61,2,3,283
PREWARM_SEASON=2025

# Optional: Vercel KV — limita cereri anonime warm/predict pe IP/ora (sau KV_REST_API_URL / KV_REST_API_TOKEN)
# STORAGEE_KV_REST_API_URL=
# STORAGEE_KV_REST_API_TOKEN=
# ANON_RATE_WARM_PER_HOUR=24
# ANON_RATE_PREDICT_PER_HOUR=16

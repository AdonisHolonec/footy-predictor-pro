{
  "functions": {
    "api/cron/warm-predict.js": {
      "maxDuration": 300
    },
    "api/cron/daily-ml.js": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/history?sync=1&days=30",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/history?sync=1&days=30",
      "schedule": "35 8 * * *"
    },
    {
      "path": "/api/history?sync=1&days=30",
      "schedule": "30 21 * * *"
    },
    {
      "path": "/api/backtest?view=snapshot&days=45",
      "schedule": "15 3 * * *"
    },
    {
      "path": "/api/cron/daily-ml?mode=all",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/cache/prewarm",
      "schedule": "1 21 * * *"
    },
    {
      "path": "/api/cache/prewarm",
      "schedule": "1 22 * * *"
    },
    {
      "path": "/api/cron/warm-predict",
      "schedule": "2 21 * * *"
    }
  ]
}
